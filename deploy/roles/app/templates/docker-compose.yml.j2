version: "3.9"

x-app-env: &app_env
  APP_ENV: ${APP_ENV}
  APP_ASYNC_DATABASE_URL: ${APP_ASYNC_DATABASE_URL}
  APP_SYNC_DATABASE_URL: ${APP_SYNC_DATABASE_URL}
  APP_CELERY_BROKER_URL: ${APP_CELERY_BROKER_URL}
  APP_CELERY_RESULT_BACKEND: ${APP_CELERY_RESULT_BACKEND}
  SECRET_KEY: ${SECRET_KEY}

services:
  postgres:
    image: postgres:16
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    volumes:
      - /opt/sweep-app/postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER} -d ${POSTGRES_DB}"]
      interval: 5s
      timeout: 5s
      retries: 20
    restart: unless-stopped

  redis:
    image: redis:7
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - /opt/sweep-app/redis:/data
    restart: unless-stopped

  api:
    image: ${APP_IMAGE}:${APP_IMAGE_TAG}
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000
    environment: *app_env
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
    ports:
      - "${APP_PORT}:8000"
    restart: unless-stopped

  worker_1:
    image: ${APP_IMAGE}:${APP_IMAGE_TAG}
    command: celery -A app.celery_app:celery_app worker --loglevel=INFO --hostname=worker1@%h --concurrency=${CELERY_WORKER_CONCURRENCY}
    environment: *app_env
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
    restart: unless-stopped

  worker_2:
    image: ${APP_IMAGE}:${APP_IMAGE_TAG}
    command: celery -A app.celery_app:celery_app worker --loglevel=INFO --hostname=worker2@%h --concurrency=${CELERY_WORKER_CONCURRENCY}
    environment: *app_env
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
    restart: unless-stopped

  worker_3:
    image: ${APP_IMAGE}:${APP_IMAGE_TAG}
    command: celery -A app.celery_app:celery_app worker --loglevel=INFO --hostname=worker3@%h --concurrency=${CELERY_WORKER_CONCURRENCY}
    environment: *app_env
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
    restart: unless-stopped
