# Rendered by Ansible. /opt/sweep-app/.env on the target host (mode 0600).
# Loaded by `docker compose --env-file` so values are visible to compose
# substitution AND inherited by services that re-export them.

# --- image / build ---
APP_IMAGE={{ app_image }}
APP_IMAGE_TAG={{ app_image_tag }}

# --- runtime ---
APP_ENV={{ app_env }}
APP_PORT={{ app_port | default('8000') }}
COMPOSE_PROJECT_NAME={{ compose_project_name | default('sweep-app') }}

# --- postgres ---
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}
POSTGRES_MAX_CONNECTIONS={{ postgres_max_connections | default('600') }}
POSTGRES_SHARED_BUFFERS={{ postgres_shared_buffers | default('256MB') }}

# --- secrets ---
SECRET_KEY={{ secret_key }}

# --- service URLs (TLS-terminated postgres uses sslmode=verify-full + the
# self-signed cert generated on first boot of the postgres container) ---
APP_ASYNC_DATABASE_URL={{ database_url_async }}
APP_ASYNC_PG_SSL_CA_FILE={{ async_pg_ssl_ca_file | default('/etc/ssl/postgres/server.crt') }}
APP_SYNC_DATABASE_URL={{ database_url_sync }}
APP_CELERY_BROKER_URL={{ app_celery_broker_url }}
APP_CELERY_RESULT_BACKEND={{ app_celery_result_backend }}

# --- pool sizing (api side) ---
API_ASYNC_DB_POOL_SIZE={{ api_async_db_pool_size | default('55') }}
API_ASYNC_DB_MAX_OVERFLOW={{ api_async_db_max_overflow | default('50') }}
API_SYNC_DB_POOL_SIZE={{ api_sync_db_pool_size | default('40') }}
API_SYNC_DB_MAX_OVERFLOW={{ api_sync_db_max_overflow | default('60') }}

# --- pool sizing (worker child procs — keep tiny, 1 task per child) ---
WORKER_SYNC_DB_POOL_SIZE={{ worker_sync_db_pool_size | default('1') }}
WORKER_SYNC_DB_MAX_OVERFLOW={{ worker_sync_db_max_overflow | default('2') }}

# --- celery / web ---
WEB_CONCURRENCY={{ web_concurrency | default('2') }}
CELERY_WORKER_CONCURRENCY={{ celery_worker_concurrency | default('8') }}

# --- worker tier replica counts (consumed by the compose --scale flags
# in the Ansible task — NOT by compose itself) ---
WORKER_EXEC_REPLICAS={{ worker_exec_replicas | default('12') }}
WORKER_AGGREGATE_REPLICAS={{ worker_aggregate_replicas | default('2') }}
WORKER_SWEEP_FINALIZE_REPLICAS={{ worker_sweep_finalize_replicas | default('2') }}
