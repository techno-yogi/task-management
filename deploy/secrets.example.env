# Example deployment secrets file. Copy to secrets.staging.env (or similar)
# and fill in real values. NEVER commit a populated copy. Use the helper:
#
#   pwsh ./scripts/setup_github_secrets.ps1 -EnvFile deploy/secrets.staging.env -Environment staging
#
# which mass-imports each KEY into the GitHub `staging` environment via `gh
# secret set`. Lines starting with `#` and blank lines are skipped.

# ---- SSH access ----
# Multi-line value: paste the full contents of the deploy private key (no
# passphrase) AND a `ssh-keyscan` snapshot of the target host respectively.
# `gh secret set` reads from stdin so multi-line values are supported.
SSH_PRIVATE_KEY=__paste_private_key_here__
SSH_HOST=staging.example.com
SSH_KNOWN_HOSTS=__paste_ssh-keyscan_output_here__

# ---- App runtime ----
APP_ENV=staging
APP_PORT=8000

# ---- Postgres ----
POSTGRES_USER=app
POSTGRES_PASSWORD=__rotate_me__
POSTGRES_DB=appdb

# ---- App secret ----
SECRET_KEY=__generate_with: python -c 'import secrets;print(secrets.token_urlsafe(64))'__

# ---- Service URLs (use service DNS names from the rendered docker-compose) ----
DATABASE_URL_ASYNC=postgresql+asyncpg://app:__rotate_me__@postgres:5432/appdb
DATABASE_URL_SYNC=postgresql+psycopg://app:__rotate_me__@postgres:5432/appdb?sslmode=verify-full&sslrootcert=/etc/ssl/postgres/server.crt
APP_CELERY_BROKER_URL=redis://redis:6379/0
APP_CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- Sizing ----
WEB_CONCURRENCY=2
CELERY_WORKER_CONCURRENCY=8
