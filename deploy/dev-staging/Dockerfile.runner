# Ansible control-node image used to run the deploy playbook against the
# `linux_staging` container. Mirrors what the GitHub Actions runner installs:
# ansible 9.x + community.docker collection.

FROM python:3.12-slim

ENV PIP_NO_CACHE_DIR=1 PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      openssh-client \
      sshpass \
      git \
      ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && pip install "ansible>=9,<11" "ansible-lint>=24,<26"

COPY requirements.yml /tmp/requirements.yml
RUN ansible-galaxy collection install -r /tmp/requirements.yml \
 && rm /tmp/requirements.yml

WORKDIR /work

CMD ["ansible", "--version"]
